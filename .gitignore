# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Environment files - DO NOT COMMIT
.env
.env.local
.env.development
.env.production
.env.test
.env*.local
.env.appwrite

# Keep the example file for documentation
!.env.example

# Google or platform config files
google-services.json
android/app/google-services.json
ios/GoogleService-Info.plist

# Android build artifacts and keystores
android/app/build/
android/build/
*.keystore

# typescript
*.tsbuildinfo
server_side/database-connection-info
# Python
server_side/venv/
server_side/__pycache__/
server_side/*.pyc
*.egg-info/
.pytest_cache/