# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git!
#
# For Expo apps, variables must be prefixed with EXPO_PUBLIC_
# to be accessible in client-side code
# ============================================

# --------------------------------------------
# APPWRITE CONFIGURATION
# --------------------------------------------
# Your Appwrite server endpoint (replace with your Appwrite host)
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://your-appwrite-server/v1

# Your Appwrite project ID (found in Appwrite Console)
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Your main database ID
EXPO_PUBLIC_APPWRITE_DATABASE_ID=your_database_id_here

# --------------------------------------------
# APPWRITE COLLECTIONS
# --------------------------------------------
# Collection ID for inventory items
EXPO_PUBLIC_COLLECTION_INVENTORY=your_inventory_collection_id_here

# Collection ID for customers
EXPO_PUBLIC_COLLECTION_CUSTOMERS=your_customers_collection_id_here

# Collection ID for sales records
EXPO_PUBLIC_COLLECTION_SALES=your_sales_collection_id_here

# Collection ID for autofill data
EXPO_PUBLIC_COLLECTION_AUTOFILL=your_autofill_collection_id_here

# Collection ID for user roles
EXPO_PUBLIC_COLLECTION_USER_ROLES=user_roles

# --------------------------------------------
# GOOGLE AUTHENTICATION
# --------------------------------------------
# Google Web Client ID from Google Cloud Console
# Get this from: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# Appwrite function URL for Google native sign-in
EXPO_PUBLIC_GOOGLE_SIGNIN_FUNCTION_URL=https://syd.cloud.appwrite.io/v1/functions/google-native-signin/executions

# --------------------------------------------
# DEEP LINK CONFIGURATION
# --------------------------------------------
# Deep link scheme for OAuth callbacks
# Format: appwrite-callback-{PROJECT_ID}
EXPO_PUBLIC_DEEP_LINK_SCHEME=appwrite-callback-your_project_id_here

# --------------------------------------------
# APPLICATION IDENTIFIERS
# --------------------------------------------
# Android package name (reverse domain notation)
EXPO_PUBLIC_ANDROID_PACKAGE=com.yourcompany.yourapp

# iOS bundle identifier (reverse domain notation)
EXPO_PUBLIC_IOS_BUNDLE_ID=com.yourcompany.yourapp

# --------------------------------------------
# EAS BUILD CONFIGURATION
# --------------------------------------------
# EAS project ID (from Expo)
EXPO_PUBLIC_EAS_PROJECT_ID=your_eas_project_id_here

# --------------------------------------------
# APPLICATION METADATA
# --------------------------------------------
# Application display name
EXPO_PUBLIC_APP_NAME=Lốp xe Toàn Thắng
